<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <staticContent>
            <remove fileExtension=".cho" />
            <remove fileExtension=".chopro" />
            <remove fileExtension=".webp" />
            <mimeMap fileExtension=".cho" mimeType="text/plain" />
            <mimeMap fileExtension=".chopro" mimeType="text/plain" />
            <mimeMap fileExtension=".webp" mimeType="image/webp" />
        </staticContent>
    </system.webServer>
</configuration>
